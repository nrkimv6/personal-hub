{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"common\\tools\\hooks\\plan-write-postcommit.ps1\" -Surface codex",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
