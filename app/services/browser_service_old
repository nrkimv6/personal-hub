    async def initialize(self):
        """브라우저 서비스의 비동기 초기화를 수행합니다."""
        logger.info("BrowserService.initialize() 메소드 시작")
        # 브라우저 초기화
        await self.initialize_browser()
        # 리소스 정리 태스크 시작
        await self.start_resource_monitoring_async()
        logger.info("BrowserService.initialize() 메소드 완료")
        return self

    async def start_resource_monitoring_async(self):
        """리소스 모니터링 및 정리 태스크를 비동기적으로 시작합니다."""
        logger.info("start_resource_monitoring_async 호출됨")
        if self.resource_cleanup_task is None:
            logger.info("리소스 모니터링 태스크 생성 시작")
            self.resource_cleanup_task = asyncio.create_task(self.monitor_resources())
            logger.info("리소스 모니터링 태스크가 시작되었습니다")

    def start_resource_monitoring(self):
        """리소스 모니터링 및 정리 태스크를 시작합니다. (이벤트 루프가 실행 중일 때만 호출해야 함)"""
        if self.resource_cleanup_task is None:
            try:
                self.resource_cleanup_task = asyncio.create_task(self.monitor_resources())
                logger.info("리소스 모니터링 태스크가 시작되었습니다")
            except RuntimeError as e:
                logger.error(f"리소스 모니터링 태스크 시작 실패: {str(e)}")
                logger.warning("이벤트 루프가 없어 리소스 모니터링 태스크를 시작할 수 없습니다. 비동기 컨텍스트에서 initialize() 메소드를 호출하세요.")

    async def monitor_resources(self):
        """리소스 사용량을 모니터링하고 필요시 정리합니다."""
        logger.info("monitor_resources 태스크 시작")
        try:
            # 종료 플래그 추가
            self._running = True
            while self._running:
                current_time = time.time()
                
                # 워커별 메모리 사용량 확인 및 정리
                for target_id in list(self.tab_pools.keys()):
                    if not self._running:
                        break
                    try:
                        await self.check_worker_memory(target_id)
                    except Exception as e:
                        logger.error(f"워커 메모리 체크 오류: {str(e)}")
                
                # 안전장치: 중간에 태스크가 취소되었는지 확인
                if not self._running:
                    break
                    
                # 주기적인 전체 정리 수행
                if current_time - self.last_global_cleanup_time > self.GLOBAL_CLEANUP_INTERVAL:
                    try:
                        await self.perform_global_cleanup()
                        self.last_global_cleanup_time = current_time
                    except Exception as e:
                        logger.error(f"전체 정리 오류: {str(e)}")
                
                # 다음 확인까지 대기 (짧은 간격으로 여러 번 대기하여 취소에 더 빨리 응답)
                for _ in range(6):  # 10초씩 6번 = 약 1분
                    if not self._running:
                        break
                    await asyncio.sleep(10)
        except asyncio.CancelledError:
            logger.info("리소스 모니터링 태스크가 취소되었습니다")
            self._running = False
        except Exception as e:
            logger.error(f"리소스 모니터링 오류 발생: {str(e)}")
            self._running = False
            # 태스크가 예외로 종료되었을 때 5초 후 재시작
            await asyncio.sleep(5)
            if hasattr(self, '_running') and self._running:
                logger.info("리소스 모니터링 태스크 재시작")
                self.resource_cleanup_task = asyncio.create_task(self.monitor_resources())
        finally:
            logger.info("monitor_resources 태스크 종료")
            self._running = False

    async def check_worker_memory(self, target_id: int):
        """특정 워커의 메모리 사용량을 확인하고 필요시 정리합니다."""
        current_time = time.time()
        
        # 마지막 확인 이후 충분한 시간이 지났는지 확인
        if target_id in self.last_memory_check and current_time - self.last_memory_check[target_id] < self.MEMORY_CHECK_INTERVAL:
            return
        
        # 현재 프로세스의 메모리 사용량 확인
        process = psutil.Process(os.getpid())
        memory_info = process.memory_info()
        memory_mb = memory_info.rss / (1024 * 1024)  # MB 단위로 변환
        
        # 메모리 통계 업데이트
        if target_id not in self.memory_stats:
            self.memory_stats[target_id] = {"initial": memory_mb, "current": memory_mb, "peak": memory_mb}
        else:
            self.memory_stats[target_id]["current"] = memory_mb
            if memory_mb > self.memory_stats[target_id]["peak"]:
                self.memory_stats[target_id]["peak"] = memory_mb
        
        self.last_memory_check[target_id] = current_time
        
        # 로그 출력
        logger.info(f"대상 {target_id}의 메모리 사용량: {memory_mb:.2f}MB")
        
        # 메모리 사용량이 임계값을 초과하면 정리 작업 수행
        if memory_mb > self.MEMORY_THRESHOLD_MB and target_id in self.tab_pools and len(self.tab_pools[target_id]) > 1:
            logger.info(f"대상 {target_id}의 메모리 사용량이 임계값을 초과하여 정리를 시작합니다.")
            await self.cleanup_target_resources(target_id)

    async def cleanup_target_resources(self, target_id: int):
        """특정 대상의 리소스를 정리합니다."""
        try:
            # 사용 중이지 않은 모든 탭 정리
            if target_id in self.tab_pools:
                tab_count_before = len(self.tab_pools[target_id])
                await self.cleanup_old_tabs(target_id, force_cleanup=True)
                tab_count_after = len(self.tab_pools[target_id]) if target_id in self.tab_pools else 0
                
                logger.info(f"대상 {target_id}의 탭 정리 완료: {tab_count_before} -> {tab_count_after}")
                
                # 캐시 정리 명령어 실행
                if target_id in self.tab_pools:
                    # 최소 하나의 탭은 남겨두기
                    if target_id in self.tab_pools and len(self.tab_pools[target_id]) > 0:
                        tab = next(iter(self.tab_pools[target_id].values()))
                        try:
                            # 메모리 캐시 정리를 위한 자바스크립트 실행
                            await tab.evaluate("""() => {
                                try {
                                    if (window.performance && window.performance.memory) {
                                        console.log('Memory usage before cleanup:', window.performance.memory.usedJSHeapSize / 1024 / 1024, 'MB');
                                    }
                                    if (window.gc) { window.gc(); }
                                } catch (e) {
                                    console.error('Error during browser cleanup:', e);
                                }
                            }""")
                        except Exception as e:
                            logger.warning(f"브라우저 캐시 정리 중 오류 발생: {str(e)}")
            
            # 가비지 컬렉션 강제 실행
            gc.collect()
            
            # 메모리 사용량 다시 확인
            process = psutil.Process(os.getpid())
            memory_after = process.memory_info().rss / (1024 * 1024)
            logger.info(f"대상 {target_id}의 정리 후 메모리 사용량: {memory_after:.2f}MB")
            
            # 메모리 통계 업데이트
            if target_id in self.memory_stats:
                self.memory_stats[target_id]["current"] = memory_after
            
        except Exception as e:
            logger.error(f"대상 {target_id}의 리소스 정리 중 오류 발생: {str(e)}")

    async def perform_global_cleanup(self):
        """모든 리소스에 대한 전체 정리를 수행합니다."""
        logger.info("전체 리소스 정리를 시작합니다...")
        
        try:
            # 모든 대상에 대해 리소스 정리 수행
            for target_id in list(self.tab_pools.keys()):
                await self.cleanup_target_resources(target_id)
            
            # 사용하지 않는 탭 정리
            inactive_targets = []
            for target_id in list(self.tab_pools.keys()):
                if target_id not in self.monitoring_tasks or self.monitoring_tasks[target_id].done():
                    inactive_targets.append(target_id)
            
            # 비활성 대상 정리
            for target_id in inactive_targets:
                logger.info(f"비활성 대상 {target_id}의 탭을 정리합니다.")
                
                if target_id in self.tab_pools:
                    # 모든 탭 닫기
                    for tab_id, tab in list(self.tab_pools[target_id].items()):
                        try:
                            await tab.close()
                        except Exception as e:
                            logger.warning(f"탭 닫기 실패: {str(e)}")
                    
                    del self.tab_pools[target_id]
                
                if target_id in self.tab_last_used:
                    del self.tab_last_used[target_id]
                
                if target_id in self.tab_in_use:
                    del self.tab_in_use[target_id]
                
                if target_id in self.memory_stats:
                    del self.memory_stats[target_id]
                
                if target_id in self.last_memory_check:
                    del self.last_memory_check[target_id]
            
            # 메모리 상태 보고
            process = psutil.Process(os.getpid())
            memory_info = process.memory_info()
            memory_mb = memory_info.rss / (1024 * 1024)
            
            if len(inactive_targets) > 0:
                status_message = (
                    f"[시스템 상태 보고]\n\n"
                    f"전체 리소스 정리 완료\n"
                    f"정리된 대상 수: {len(inactive_targets)}\n"
                    f"현재 메모리 사용량: {memory_mb:.2f}MB\n"
                    f"활성 탭 그룹: {len(self.tab_pools)}\n"
                    f"활성 모니터링 태스크: {len(self.monitoring_tasks)}"
                )
                await self.notification_service.send_telegram(status_message, force_send=True)
        
        except Exception as e:
            logger.error(f"전체 리소스 정리 중 오류 발생: {str(e)}")

    async def initialize_browser(self) -> BrowserContext:
        """단일 브라우저 컨텍스트를 초기화합니다."""
        if self.browser_context is not None:
            return self.browser_context

        # 프로필 디렉토리 설정
        profile_dir = Path(settings.USER_DATA_DIR) / "browser_profile"
        os.makedirs(profile_dir, exist_ok=True)

        try:
            # Playwright 초기화 
            logger.info("Playwright 브라우저 초기화 시작")
            self.playwright_instance = await async_playwright().start()
            
            # launch_persistent_context 사용 - 사용자 데이터 경로 유지를 위해
            self.browser_context = await self.playwright_instance.chromium.launch_persistent_context(
                user_data_dir=str(profile_dir),
                headless=False,
                args=[
                    '--disable-blink-features=AutomationControlled',
                    '--disable-features=IsolateOrigins,site-per-process',
                    '--disable-site-isolation-trials',
                    '--no-sandbox',
                    '--disable-setuid-sandbox',
                    '--disable-dev-shm-usage',
                    '--disable-accelerated-2d-canvas',
                    '--disable-gpu',
                    '--window-size=1920,1080',
                ],
                viewport={'width': 1920, 'height': 1080},
                user_agent='Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
            )

            # 자바스크립트 주입으로 자동화 감지 방지 추가
            await self._bypass_automation_detection(self.browser_context)
            
            # 메모리 모니터링 초기화
            process = psutil.Process(os.getpid())
            memory_mb = process.memory_info().rss / (1024 * 1024)
            self.memory_stats["browser"] = {"initial": memory_mb, "current": memory_mb, "peak": memory_mb}
            self.last_memory_check["browser"] = time.time()
            
            logger.info(f"단일 브라우저 컨텍스트 초기화 완료. 프로필 디렉토리: {profile_dir}")
            return self.browser_context
        except Exception as e:
            logger.error(f"브라우저 초기화 중 오류 발생: {str(e)}", exc_info=True)
            # 실패 시 예외 다시 발생
            raise

    async def _bypass_automation_detection(self, context: BrowserContext):
        """자동화 감지를 우회하기 위한 스크립트를 주입합니다."""
        # 모든 새 페이지에 적용할 스크립트
        await context.add_init_script("""
        // navigator.webdriver 제거
        if (navigator.webdriver === true) {
            Object.defineProperty(navigator, 'webdriver', {
                get: () => false
            });
        }
        
        // plugins 속성 수정
        if (navigator.plugins.length === 0) {
            Object.defineProperty(navigator, 'plugins', {
                get: () => [1, 2, 3, 4, 5]
            });
        }
        
        // 자동화 감지에 사용되는 다른 속성 속이기
        Object.defineProperty(navigator, 'maxTouchPoints', {
            get: () => 1
        });
        """)

    async def cleanup_old_tabs(self, target_id: int, force_cleanup: bool = False):
        """오래된 탭을 정리합니다."""
        current_time = time.time()
        tabs_to_remove = []
        
        if target_id not in self.tab_last_used:
            return
        
        # 정리할 탭의 수 결정 (강제 정리 모드에서는 더 많은 탭 정리)
        max_tabs = settings.MAX_TABS_PER_WORKER
        optimal_tabs = max(1, max_tabs // 2)  # 최적 탭 수는 최대 탭 수의 절반 (최소 1개)
        
        # 모든 탭의 마지막 사용 시간 확인
        tab_usage = [(tab_id, last_used) for tab_id, last_used in self.tab_last_used[target_id].items()]
        
        # 사용 시간 기준으로 정렬 (오래된 순)
        tab_usage.sort(key=lambda x: x[1])
        
        # 강제 정리 모드에서는 오래된 탭 우선 제거, 일반 모드에서는 임계값 초과 탭만 제거
        if force_cleanup:
            # 탭이 optimal_tabs보다 많으면 가장 오래된 탭부터 제거
            if len(tab_usage) > optimal_tabs:
                tabs_to_remove = [tab_id for tab_id, _ in tab_usage[:-optimal_tabs]]
                logger.info(f"대상 {target_id}의 강제 탭 정리: {len(tabs_to_remove)}개 정리 대상")
        else:
            # 임계값을 초과한 탭만 제거
            for tab_id, last_used in tab_usage:
                if current_time - last_used > settings.TAB_CLEANUP_THRESHOLD:
                    tabs_to_remove.append(tab_id)
            if tabs_to_remove:
                logger.info(f"대상 {target_id}의 오래된 탭 정리: {len(tabs_to_remove)}개 정리 대상 (임계값: {settings.TAB_CLEANUP_THRESHOLD}초)")
        
        # 만약 모든 탭이 제거 대상이면 가장 최근에 사용한 탭 하나는 유지
        if tabs_to_remove and len(tabs_to_remove) >= len(self.tab_last_used[target_id]):
            newest_tab = tab_usage[-1][0]  # 가장 최근에 사용된 탭
            if newest_tab in tabs_to_remove:
                tabs_to_remove.remove(newest_tab)
                logger.info(f"대상 {target_id}의 탭 정리: 최근 사용한 탭 {newest_tab} 유지")
        
        # 제거 대상 탭 정리
        for tab_id in tabs_to_remove:
            if tab_id in self.tab_pools.get(target_id, {}):
                try:
                    logger.debug(f"대상 {target_id}의 {'오래된' if not force_cleanup else '강제'} 탭 {tab_id} 정리 시작")
                    await self.tab_pools[target_id][tab_id].close()
                    del self.tab_pools[target_id][tab_id]
                    del self.tab_last_used[target_id][tab_id]
                    if tab_id in self.tab_in_use.get(target_id, {}):
                        del self.tab_in_use[target_id][tab_id]
                    
                    # 전체 활성 탭 수 감소
                    self.total_active_tabs = max(0, self.total_active_tabs - 1)
                    
                    logger.debug(f"대상 {target_id}의 탭 {tab_id} 정리 완료 (전체 활성 탭 수: {self.total_active_tabs})")
                except Exception as e:
                    logger.warning(f"탭 정리 중 오류 발생: {str(e)}")
        
        # 정리 후 남아있는 탭 수 확인
        remaining_tabs = len(self.tab_pools.get(target_id, {}))
        logger.info(f"대상 {target_id}의 탭 정리 후 남은 탭 수: {remaining_tabs}")
        
        return len(tabs_to_remove)  # 정리된 탭 수 반환

    async def get_tab(self, target_id: int) -> Page:
        """사용 가능한 탭을 가져오거나 새로 생성합니다."""
        # 브라우저가 초기화되지 않았다면 초기화
        if self.browser_context is None:
            await self.initialize_browser()
        
        # 대기 구조 초기화
        if target_id not in self.tab_waiters:
            self.tab_waiters[target_id] = {}
        
        # 고유 요청 ID 생성
        request_id = f"req_{int(time.time())}_{random.randint(1000, 9999)}"
        
        # 오래된 탭 정리
        removed_tabs = await self.cleanup_old_tabs(target_id)
        
        # 워커의 탭 풀이 없으면 초기화
        if target_id not in self.tab_pools:
            self.tab_pools[target_id] = {}
            self.tab_last_used[target_id] = {}
            self.tab_in_use[target_id] = {}
            logger.info(f"대상 {target_id}의 탭 풀 초기화")
        
        # 탭 회전 주기 확인 - 일정 횟수의 요청마다 강제로 탭 교체
        tab_rotation_count = getattr(self, 'tab_rotation_count', {}).get(target_id, 0)
        
        # 탭 회전 카운터 초기화
        if not hasattr(self, 'tab_rotation_count'):
            self.tab_rotation_count = {}
        if target_id not in self.tab_rotation_count:
            self.tab_rotation_count[target_id] = 0
        
        # 설정된 임계값 이상으로 탭 요청 시 교체 (메모리 누수 방지)
        force_new_tab = self.tab_rotation_count[target_id] >= self.TAB_ROTATION_THRESHOLD
        if force_new_tab:
            logger.info(f"대상 {target_id}의 탭 교체 주기 도달 ({self.TAB_ROTATION_THRESHOLD}회)")
            self.tab_rotation_count[target_id] = 0
        else:
            self.tab_rotation_count[target_id] += 1
        
        # 탭 획득 시도 시작
        start_time = time.time()
        wait_count = 0
        max_wait_time = self.TAB_REQUEST_TIMEOUT  # 최대 대기 시간 (초)
        
        while True:
            # 시간 초과 확인
            if time.time() - start_time > max_wait_time:
                logger.warning(f"대상 {target_id}의 탭 요청이 {max_wait_time}초를 초과하여 시간 초과로 간주")
                raise TimeoutError(f"탭 요청 시간 초과 (대상 ID: {target_id}, 요청 ID: {request_id})")
            
            # 사용 가능한 탭 찾기 (사용 중이 아닌 탭만 고려)
            available_tabs = [tab_id for tab_id in self.tab_pools[target_id].keys() 
                            if not self.tab_in_use[target_id].get(tab_id, False)]
            
            # 탭 선택 로직
            use_existing_tab = len(available_tabs) > 0 and not force_new_tab
            
            if use_existing_tab:
                # 사용 가능한(사용 중이 아닌) 탭이 있으면 선택 방식 결정
                if len(available_tabs) <= 2:
                    # 탭이 적으면 최근 사용 탭 재사용 (캐시 활용)
                    free_tab_times = [(tab_id, self.tab_last_used[target_id][tab_id]) 
                                    for tab_id in available_tabs]
                    tab_id = max(free_tab_times, key=lambda x: x[1])[0]
                    logger.debug(f"대상 {target_id}의 최근 사용 탭 {tab_id} 재사용 (탭 수 적음)")
                else:
                    # 탭이 많으면 랜덤하게 선택 (탐지 방지 효과)
                    tab_id = random.choice(available_tabs)
                    logger.debug(f"대상 {target_id}의 랜덤 탭 {tab_id} 선택 (탭 수 충분)")
                
                tab = self.tab_pools[target_id][tab_id]
                logger.info(f"대상 {target_id}의 기존 탭 {tab_id} 재사용 (회전 카운터: {self.tab_rotation_count[target_id]}/{self.TAB_ROTATION_THRESHOLD})")
                
                # 페이지 상태 초기화 - 브라우저 캐시 및 스토리지 정리 (메모리 누수 방지)
                if self.tab_rotation_count[target_id] % self.CACHE_CLEANUP_INTERVAL == 0:
                    try:
                        logger.debug(f"대상 {target_id}의 탭 {tab_id} 캐시 정리 ({self.CACHE_CLEANUP_INTERVAL}회 주기)")
                        # 캐시 정리
                        await tab.evaluate("""() => {
                            try {
                                // 세션 스토리지 정리
                                sessionStorage.clear();
                                // 로컬 스토리지 정리
                                localStorage.clear();
                                // 메모리 정리 힌트
                                if (window.gc) { window.gc(); }
                                console.log('Page cache cleared');
                            } catch (e) {}
                        }""")
                    except Exception as e:
                        logger.warning(f"탭 캐시 정리 중 오류: {str(e)}")
                
                # 탭 획득 성공, 사용 시작
                break
            else:
                # 새 탭 생성이 필요한 경우
                need_new_tab = force_new_tab or len(self.tab_pools[target_id]) < settings.MAX_TABS_PER_WORKER
                
                # 전체 탭 수 제한 확인
                total_tabs = sum(len(tabs) for tabs in self.tab_pools.values())
                if total_tabs >= self.TOTAL_MAX_TABS:
                    logger.warning(f"전체 탭 수 제한({self.TOTAL_MAX_TABS}개)에 도달. 현재 탭 수: {total_tabs}개")
                    need_new_tab = False
                
                if need_new_tab:
                    # 새 탭 생성 - 단일 브라우저 컨텍스트 사용
                    tab = await self.browser_context.new_page()
                    
                    # 추가 자동화 감지 방지 설정
                    await tab.set_extra_http_headers({
                        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
                        'Accept-Language': 'ko-KR,ko;q=0.9,en-US;q=0.8,en;q=0.7'
                    })
                    
                    # 무작위 탭 ID 부여 (탐지 방지)
                    tab_id = str(random.randint(1000, 9999))
                    while tab_id in self.tab_pools[target_id]:
                        tab_id = str(random.randint(1000, 9999))
                    
                    self.tab_pools[target_id][tab_id] = tab
                    self.tab_last_used[target_id][tab_id] = time.time()
                    self.tab_in_use[target_id][tab_id] = False  # 초기 상태: 사용 중이 아님
                    logger.info(f"대상 {target_id}의 새 탭 {tab_id} 생성 {'(강제 교체)' if force_new_tab else ''}")
                    
                    # 전체 활성 탭 수 증가
                    self.total_active_tabs += 1
                    logger.info(f"전체 활성 탭 수 증가: {self.total_active_tabs}개")
                    
                    # 탭 획득 성공, 사용 시작
                    break
                else:
                    # 모든 탭이 사용 중이고 새 탭도 만들 수 없는 경우 대기 큐에 추가
                    wait_count += 1
                    
                    if wait_count == 1:
                        # 첫 번째 대기일 때만 자세한 로그 출력
                        total_tabs = sum(len(tabs) for tabs in self.tab_pools.values())
                        worker_tabs = len(self.tab_pools.get(target_id, {}))
                        logger.info(f"대상 {target_id}의 탭 요청 {request_id}가 대기 중 (워커 탭: {worker_tabs}/{settings.MAX_TABS_PER_WORKER}, 전체 탭: {total_tabs}/{self.TOTAL_MAX_TABS})")
                    else:
                        logger.info(f"대상 {target_id}의 탭 요청 {request_id}가 대기 중 (대기 횟수: {wait_count})")
                    
                    # 대기 이벤트 생성
                    wait_event = asyncio.Event()
                    self.tab_waiters[target_id][request_id] = wait_event
                    
                    try:
                        # 사용 가능한 탭이 생길 때까지 대기
                        await asyncio.wait_for(wait_event.wait(), timeout=self.TAB_WAIT_RETRY_INTERVAL)
                        logger.info(f"대상 {target_id}의 탭 요청 {request_id}가 탭 사용 신호를 받음")
                        
                        # 탭이 사용 가능해졌으므로 다시 시도
                        # 대기 이벤트는 release_tab에서 제거됨
                        continue
                        
                    except asyncio.TimeoutError:
                        # 타임아웃 발생 시 대기자 목록에서 제거
                        self.tab_waiters[target_id].pop(request_id, None)
                        logger.info(f"대상 {target_id}의 탭 요청 {request_id} 대기 시간 초과, 다시 시도")
                        
                        # 짧은 대기 후 다시 시도
                        await asyncio.sleep(1)
                        continue
        
        # 탭 사용 시작 표시
        self.tab_in_use[target_id][tab_id] = True
        
        # 탭 사용 시간 업데이트
        self.tab_last_used[target_id][tab_id] = time.time()
        
        # 탭 ID를 탭 객체에 저장 (나중에 사용 종료 시 참조)
        tab._tab_id = tab_id
        tab._target_id = target_id
        
        return tab

    async def release_tab(self, tab: Page):
        """탭 사용을 완료하고 풀로 반환합니다."""
        try:
            # 탭에서 저장된 ID 정보 추출
            if hasattr(tab, '_tab_id') and hasattr(tab, '_target_id'):
                tab_id = tab._tab_id
                target_id = tab._target_id
                
                # 탭이 존재하는지 확인
                if (target_id in self.tab_in_use and 
                    tab_id in self.tab_in_use[target_id]):
                    # 탭 사용 상태 업데이트
                    self.tab_in_use[target_id][tab_id] = False
                    logger.info(f"대상 {target_id}의 탭 {tab_id} 사용 완료 표시")
                    
                    # 사용 시간 갱신 (가장 최근 사용)
                    self.tab_last_used[target_id][tab_id] = time.time()
                    
                    # 대기 중인 탭 요청이 있으면 처리
                    if target_id in self.tab_waiters and self.tab_waiters[target_id]:
                        for waiter_id, event in list(self.tab_waiters[target_id].items()):
                            # 사용 가능한 탭이 있으면 대기 중인 태스크에 신호 보내기
                            event.set()
                            # 이벤트를 발생시켰으면 목록에서 제거 (한 번만 실행하기 위해)
                            self.tab_waiters[target_id].pop(waiter_id, None)
                            logger.info(f"대상 {target_id}의 대기 중인 탭 요청 {waiter_id}에 신호 전송")
                            break  # 한 번에 하나의 대기자만 깨우기
                    
                    # 다른 워커에 대기 중인 탭 요청이 있는지 확인
                    for other_target_id, waiters in self.tab_waiters.items():
                        if other_target_id != target_id and waiters:
                            # 다른 워커에 대기 중인 요청이 있으면 신호 전송
                            for waiter_id, event in list(waiters.items()):
                                event.set()
                                waiters.pop(waiter_id, None)
                                logger.info(f"다른 대상 {other_target_id}의 대기 중인 탭 요청 {waiter_id}에 신호 전송")
                                break  # 한 번에 하나만 깨우기
                            break  # 한 워커에 대해서만 처리
        except Exception as e:
            logger.warning(f"탭 반환 중 오류 발생: {str(e)}")

    async def load_page(self, tab: Page, url: str) -> Tuple[Union[str, None], Union[str, None], Union[str, None]]:
        """페이지를 로드하고 콘텐츠를 반환합니다."""
        try:
            logger.info(f"페이지 로드 시작: {url}")
            # 페이지 로드 (타임아웃 30초)
            await tab.goto(url, timeout=30000, wait_until="networkidle")
            
            # 추가 대기 (부하 줄이기)
            await asyncio.sleep(2)
            
            # 콘텐츠 가져오기
            content = await tab.content()
            
            # 에러 페이지 감지 (config 설정 활용)
            if settings.ERROR_PAGE_DETECTION:
                # 매진 상태 확인
                if "error" in content:
                    logger.info(f"매진 상태 감지됨: 'error' 패턴 발견")
                    # 매진 상태는 에러가 아닌 정상 콘텐츠로 처리
                    content_hash = hash(content)
                    return content_hash, content, None
                
                # 다른 에러 패턴 확인 (error 패턴을 제외한 나머지 패턴)
                for pattern in settings.ERROR_PATTERNS:
                    if pattern != "error" and pattern in content:
                        logger.info(f"에러 페이지 감지됨: {pattern}")
                        return None, content, f"error_pattern: {pattern}"
                
                # 추가적인 에러 페이지 감지 (예: 404, 500 등)
                status_code = await tab.evaluate("""() => {
                    return window.performance && window.performance.getEntries 
                        ? window.performance.getEntries()[0].responseStatus 
                        : null;
                }""")
                
                if status_code and (status_code >= 400):
                    logger.info(f"HTTP 에러 감지됨: {status_code}")
                    return None, content, f"http_error: {status_code}"
            
            # 해시값 계산
            content_hash = hash(content)
            
            return content_hash, content, None
            
        except Exception as e:
            logger.error(f"페이지 로드 중 오류 발생: {str(e)}")
            return None, None, f"error: {str(e)}"

    async def monitor_url(self, target_id: int, url: str, label: str):
        """URL 모니터링을 수행합니다."""
        current_hash = ""
        current_data = None
        last_check_time = datetime.now()  # 초기 확인 시간 설정
        error_count = 0  # 연속 에러 횟수
        next_run_time = time.time()  # 다음 실행 시간 초기화
        check_count = 0  # 총 확인 횟수
        
        # 시작 로그
        logger.info(f"🔍 [{label}] 모니터링 태스크 시작 (대상 ID: {target_id}, URL: {url})")
        
        # 첫 실행 시 날짜 기반 간격 계산
        target = await self.monitor_service.get_target(target_id)
        if settings.DATE_BASED_SCHEDULING and (not target.custom_interval):
            # URL에서 날짜 추출하여 간격 동적 계산
            date_str = self.monitor_service.extract_date_from_url(url)
            calculated_interval = self.monitor_service.calculate_interval(date_str)
            
            if calculated_interval:
                logger.info(f"[{label}] 날짜 기반 초기 간격 계산됨: {calculated_interval:.2f}초")
                # 데이터베이스에 간격 업데이트
                await self.monitor_service.update_target(target_id, {"interval": calculated_interval, "custom_interval": False})
            else:
                # 계산 실패 시 기본값 사용
                calculated_interval = settings.CHECK_INTERVAL
                logger.info(f"[{label}] 날짜 기반 간격 계산 실패, 기본값 사용: {calculated_interval}초")

        try:
            # 모니터링 루프
            while True:
                try:
                    current_time = time.time()
                    
                    # 아직 실행 시간이 되지 않았으면 짧게 대기
                    if current_time < next_run_time:
                        # 최대 1초 대기 (짧은 슬립으로 CPU 사용량 감소 및 응답성 유지)
                        wait_time = min(1, next_run_time - current_time)
                        await asyncio.sleep(wait_time)
                        continue
                    
                    # 모니터링 대상이 비활성화되었는지 확인
                    target = await self.monitor_service.get_target(target_id)
                    if not target or not target.is_active:
                        logger.info(f"⏹️ [{label}] 모니터링 중지됨 (비활성화 또는 삭제)")
                        break
                    
                    # 체크 카운트 증가
                    check_count += 1
                    check_start_time = time.time()
                    
                    # 로그 출력 - 모니터링 진행 상황
                    logger.info(f"✓ [{label}] 확인 #{check_count} 시작 (URL: {url})")
                    
                    # 태스크가 취소되었는지 확인 (주기적으로)
                    if asyncio.current_task().cancelled():
                        logger.info(f"[{label}] 태스크가 취소되어 종료합니다.")
                        break
                    
                    # 이벤트 루프에 제어권 양보 (서버 응답성 유지)
                    await asyncio.sleep(0)
                    
                    # 탭 가져오기 (이미 사용 상태 체크 포함)
                    tab = await self.get_tab(target_id)
                    logger.info(f"[{label}] 탭 획득 성공")
                    
                    try:
                        # 페이지 로드 및 상태 확인
                        logger.info(f"[{label}] 페이지 로드 중...")
                        new_hash, content, error_type = await self.load_page(tab, url)
                        
                        # 에러 처리
                        if error_type:
                            error_count += 1
                            
                            # "error" 패턴이 감지된 경우 매진 상태로 처리
                            if error_type == "error_pattern: error":
                                logger.info(f"_ [{label}] 매진 상태 감지")
                                # 매진 상태는 에러가 아닌 정상 상태로 처리하여 알림 발송
                                current_hash = new_hash
                                current_data = content
                                # 변경 이벤트 발생
                                asyncio.create_task(self.handle_change(target_id, url, label, content, last_check_time))
                                # 에러 카운트 초기화
                                error_count = 0
                                # 다음 실행 시간 설정 (정상 간격 사용)
                                last_check_time = datetime.now()
                                interval = settings.CHECK_INTERVAL
                                next_run_time = time.time() + interval
                                logger.info(f"⏱️ [{label}] 다음 실행 예정: {datetime.fromtimestamp(next_run_time).strftime('%Y-%m-%d %H:%M:%S')} (간격: {interval:.2f}초)")
                            else:
                                # 기타 에러 처리 (기존 코드)
                                logger.info(f"❌ [{label}] 에러 감지 (#{error_count}): {error_type}")
                                
                                # 10회 이상 연속 에러 발생 시 특별 처리
                                if error_count >= 10:
                                    # 관리자 알림
                                    error_message = f"⚠️ <b>연속 에러 감지</b>\n\n대상: {label}\nURL: {url}\n에러 유형: {error_type}\n발생 횟수: {error_count}"
                                    await self.notification_service.send_telegram(error_message, force_send=True)
                                    error_count = 0  # 알림 후 카운터 초기화
                                
                                # 에러 발생 시 짧은 간격으로 다음 실행 시간 설정
                                next_run_time = time.time() + min(60, settings.CHECK_INTERVAL / 4)
                        else:
                            # 정상 처리 시 에러 카운터 초기화
                            error_count = 0
                            
                            # 콘텐츠 상태 로깅
                            content_length = len(content) if content else 0
                            hash_info = new_hash[:10] + "..." if new_hash else "없음"
                            logger.info(f"[{label}] 로드 완료 - 길이: {content_length}, 해시: {hash_info}")
                            
                            # 컨텐츠가 없거나 해시값이 없는 경우
                            if new_hash is None or content is None:
                                logger.info(f"⚠️ [{label}] 유효하지 않은 응답 감지")
                                # 기본 간격으로 다음 실행 시간 설정
                                next_run_time = time.time() + settings.CHECK_INTERVAL
                            else:
                                # 변경 감지
                                if new_hash != current_hash:
                                    logger.info(f"🔄 [{label}] 변경 감지됨")
                                    # 변경 사항 처리
                                    current_hash = new_hash
                                    current_data = content
                                    
                                    # 변경 이벤트 발생 (알림 등) - 이벤트 루프 차단 방지를 위해 별도 태스크로 실행
                                    asyncio.create_task(self.handle_change(target_id, url, label, content, last_check_time))
                                    
                                    # 이벤트 루프에 제어권 양보
                                    await asyncio.sleep(0)
                                else:
                                    logger.info(f"[{label}] 변경 없음")
                                
                                # 현재 확인 시간 업데이트
                                last_check_time = datetime.now()
                                
                                # 다음 실행 시간 동적 계산
                                interval = settings.CHECK_INTERVAL  # 기본값
                                
                                # 간격 계산 로직 결정
                                if target.custom_interval and target.interval is not None:
                                    # 사용자 정의 간격 사용
                                    interval = target.interval
                                    logger.info(f"[{label}] 사용자 정의 간격 사용: {interval:.2f}초")
                                elif settings.DATE_BASED_SCHEDULING:
                                    # 날짜 기반 동적 간격 계산
                                    date_str = self.monitor_service.extract_date_from_url(url)
                                    calculated_interval = self.monitor_service.calculate_interval(date_str)
                                    
                                    if calculated_interval:
                                        interval = calculated_interval
                                        logger.info(f"[{label}] 날짜 기반 간격 재계산됨: {interval:.2f}초")
                                        
                                        # 간격이 크게 변경된 경우 DB에 업데이트
                                        if not target.interval or abs(target.interval - interval) > 10:
                                            await self.monitor_service.update_target(target_id, {"interval": interval, "custom_interval": False})
                                
                                # 다음 실행 시간 설정
                                next_run_time = time.time() + interval
                                next_time_str = datetime.fromtimestamp(next_run_time).strftime('%Y-%m-%d %H:%M:%S')
                                logger.info(f"⏱️ [{label}] 다음 실행 예정: {next_time_str} (간격: {interval:.2f}초)")
                    finally:
                        # 작업 완료 후 항상 탭 반환 
                        await self.release_tab(tab)
                        
                        # 작업 완료 시간 측정 및 로깅
                        check_duration = time.time() - check_start_time
                        logger.info(f"⌛ [{label}] 확인 #{check_count} 완료 (소요 시간: {check_duration:.2f}초)")
                    
                    # 각 루프 실행 후 짧은 대기 추가하여 이벤트 루프 차단 방지
                    await asyncio.sleep(0.1)

                except asyncio.CancelledError:
                    logger.info(f"[{label}] 모니터링 태스크가 취소되었습니다.")
                    break
                except Exception as e:
                    logger.error(f"❌ [{label}] 모니터링 오류: {str(e)}")
                    
                    # 오류 정보 업데이트 (상태는 유지)
                    try:
                        # 대상 정보 가져오기
                        target = await self.monitor_service.get_target(target_id)
                        if target:
                            # 오류 카운트 증가 및 상태 업데이트
                            error_count = target.error_count + 1 if hasattr(target, 'error_count') else 1
                            update_data = {
                                "run_status": "error",
                                "last_error": str(e),
                                "error_count": error_count
                            }
                            await self.monitor_service.update_target(target_id, update_data)
                            
                            # 연속 오류가 너무 많으면 자동 재시도 간격 증가
                            retry_delay = min(10 * error_count, 300)  # 최대 5분까지 지연
                            logger.info(f"[{label}] {retry_delay}초 후 재시도... (오류 횟수: {error_count})")
                        else:
                            # 대상 정보 조회 실패 시 기본 10초 후 재시도
                            retry_delay = 10
                            logger.info(f"[{label}] {retry_delay}초 후 재시도...")
                    except Exception as update_err:
                        logger.error(f"[{label}] 오류 상태 업데이트 실패: {str(update_err)}")
                        retry_delay = 10
                    
                    # 다음 실행 시간 설정
                    next_run_time = time.time() + retry_delay
                    
                    # 서버 응답성을 위해 이벤트 루프에 제어권 양보
                    await asyncio.sleep(0.1)
        
        except asyncio.CancelledError:
            logger.info(f"[{label}] 모니터링 태스크 취소됨 (대상 ID: {target_id})")
        except Exception as e:
            logger.error(f"[{label}] 모니터링 태스크 전역 오류: {str(e)}", exc_info=True)
        finally:
            logger.info(f"[{label}] 모니터링 태스크 종료 (대상 ID: {target_id})")
            # 실행 상태 업데이트 (활성 상태는 유지)
            try:
                await self.monitor_service.update_target(target_id, {"run_status": "stopped"})
            except Exception as e:
                logger.error(f"[{label}] 대상 상태 업데이트 실패: {str(e)}")

    async def handle_change(self, target_id: int, url: str, label: str, content: str, last_check_time: datetime):
        """변경 사항을 처리합니다."""
        try:
            # 콘텐츠 유효성 검사 수행
            is_valid = is_content_valid(content, level=2)
            is_reservation_full = is_full_reservation(content)
            is_available = is_page_available(content)
            
            # 유효성 상태 로깅
            status_message = []
            if is_valid:
                if isinstance(is_valid, list) and len(is_valid) > 0:
                    available_times = len(is_valid)
                    status_message.append(f"예약 가능 시간: {available_times}개")
                status_message.append("유효한 콘텐츠")
            else:
                status_message.append("유효하지 않은 콘텐츠")
                
            if is_reservation_full:
                status_message.append("예약 마감")
            
            if not is_available:
                status_message.append("페이지 이용 불가")
                
            logger.info(f"[{label}] 콘텐츠 상태: {', '.join(status_message)}")
            
            # 콘텐츠가 접근 불가능한 경우 추가 처리
            if not is_available:
                logger.info(f"[{label}] 페이지 접근 불가 - 알림 형식 변경")
                # 특별한 알림 형식으로 전환할 수 있음
            
            # 예약 마감인 경우 추가 처리
            if is_reservation_full:
                logger.info(f"[{label}] 예약 마감 상태 감지")
                # 예약 마감 전용 처리 가능
            
            # 변경 사항 알림 (유효성 검사 결과 포함)
            await self.notification_service.notify_change(
                target_id, 
                url, 
                label, 
                content, 
                last_check_time,
                validity_info={
                    "is_valid": is_valid is not None,
                    "is_full": is_reservation_full,
                    "is_available": is_available,
                    "valid_times": is_valid if isinstance(is_valid, list) else None
                }
            )
            
            # 변경 이력 저장 (추후 구현)
            # await self.save_change_history(target_id, content)
            
        except Exception as e:
            logger.error(f"변경 사항 처리 중 오류 발생: {str(e)}")
            # 오류 발생 시에도 계속 진행
            await self.notification_service.notify_change(target_id, url, label, content, last_check_time)

    async def start_monitoring(self, data: dict):
        """새로운 모니터링을 시작합니다."""
        try:
            logger.info(f"모니터링 시작 요청: {data}")
            
            target_id = data.get("id")
            
            # TOTAL_MAX_TABS 제한 확인
            # 현재 실행 중인 모니터링 태스크 수 확인
            active_tasks = sum(1 for task in self.monitoring_tasks.values() if not task.done())
            logger.info(f"현재 실행 중인 모니터링 태스크 수: {active_tasks}, 전체 탭 제한: {self.TOTAL_MAX_TABS}")
            
            # 대기열 초기화 (존재하지 않는 경우)
            if not hasattr(self, 'monitoring_queue'):
                self.monitoring_queue = asyncio.Queue()
                self.monitoring_queue_tasks = {}
                # 대기열 처리 태스크 시작
                self.queue_processor_task = asyncio.create_task(self._process_monitoring_queue())
                logger.info("모니터링 대기열 시스템 초기화")
            
            if target_id:
                # 이미 ID가 있는 경우 기존 대상 사용
                logger.info(f"기존 모니터링 대상 사용: ID {target_id}")
                target = await self.monitor_service.get_target(target_id)
                if not target:
                    logger.error(f"모니터링 대상을 찾을 수 없음: ID {target_id}")
                    raise ValueError(f"모니터링 대상을 찾을 수 없음: ID {target_id}")
            else:
                # 새 대상 생성
                logger.info(f"새 모니터링 대상 생성")
                # Pydantic 모델로 변환
                target_data = MonitorTargetCreate(**data)
                logger.debug(f"모니터링 타겟 데이터 변환 완료")
                
                target = await self.monitor_service.create_target(target_data)
                logger.info(f"모니터링 대상 생성 완료: ID {target.id}")
            
            # 이미 모니터링 중인지 확인
            if target.id in self.monitoring_tasks and not self.monitoring_tasks[target.id].done():
                logger.info(f"모니터링이 이미 실행 중: ID {target.id}")
                return target.id
            
            # 이미 대기열에 있는지 확인
            if target.id in self.monitoring_queue_tasks:
                logger.info(f"모니터링이 이미 대기열에 있음: ID {target.id}")
                return target.id
            
            # 전체 활성 탭 수 확인 (기존 생성된 탭)
            total_tabs = sum(len(tabs) for tabs in self.tab_pools.values())
            
            # 이미 실행 중인 모니터링 수가 TOTAL_MAX_TABS 이상이면 대기열에 추가
            if active_tasks >= self.TOTAL_MAX_TABS or total_tabs >= self.TOTAL_MAX_TABS:
                # 모니터링 상태 업데이트: 대기 중으로 표시
                update_data = {
                    "is_active": True, 
                    "run_status": "queued",  # 대기 중 상태로 표시
                    "error_count": 0,
                    "last_error": f"전체 탭 수 제한({self.TOTAL_MAX_TABS}개)에 도달하여 대기열에 추가됨"
                }
                
                # 이미 is_enabled이 False로 설정된 경우 유지 (사용자 설정 존중)
                if hasattr(target, 'is_enabled') and target.is_enabled is False:
                    update_data["is_enabled"] = False
                    
                await self.monitor_service.update_target(target.id, update_data)
                
                # 대기열에 추가
                logger.warning(f"전체 탭 수 제한({self.TOTAL_MAX_TABS}개)에 도달. 현재 활성 태스크 수: {active_tasks}개, 탭 수: {total_tabs}개")
                logger.info(f"대상 {target.id}({target.label})를 대기열에 추가합니다.")
                
                # 대기열 항목 생성 및 추가
                queue_item = {
                    "target_id": target.id,
                    "target": target,
                    "added_time": time.time()
                }
                
                # 대기열에 추가
                await self.monitoring_queue.put(queue_item)
                
                # 대기열 태스크 추적
                self.monitoring_queue_tasks[target.id] = queue_item
                
                # 현재 대기열 상태 로깅
                queue_size = self.monitoring_queue.qsize()
                logger.info(f"현재 대기 중인 모니터링 수: {queue_size}개")
                
                # 대기열 알림 전송
                try:
                    message = (
                        f"🕒 <b>모니터링 대기열 알림</b>\n\n"
                        f"대상: {target.label}\n"
                        f"상태: 대기열에 추가됨\n"
                        f"대기 순서: {queue_size}번째\n"
                        f"실행 중인 모니터링: {active_tasks}/{self.TOTAL_MAX_TABS}개\n"
                        f"사용 중인 탭: {total_tabs}/{self.TOTAL_MAX_TABS}개\n\n"
                        f"<i>탭 리소스가 확보되면 자동으로 시작됩니다.</i>"
                    )
                    from app.services.notification_service import NotificationService
                    notification_service = NotificationService()
                    await notification_service.send_telegram(message, force_send=True)
                except Exception as e:
                    logger.error(f"대기열 알림 전송 실패: {str(e)}")
                
                return target.id
            
            # 제한에 걸리지 않은 경우 바로 시작
            # 모니터링 상태 업데이트: is_active는 시스템 상태, is_enabled는 사용자 제어, run_status는 실행 상태
            update_data = {
                "is_active": True, 
                "run_status": "running",
                "error_count": 0,
                "last_error": None
            }
            
            # 이미 is_enabled이 False로 설정된 경우 유지 (사용자 설정 존중)
            if hasattr(target, 'is_enabled') and target.is_enabled is False:
                update_data["is_enabled"] = False
                
            await self.monitor_service.update_target(target.id, update_data)
            
            # 모니터링 태스크 시작: 비동기 태스크가 서버 메인 스레드를 차단하지 않도록 처리
            logger.info(f"모니터링 태스크 생성 시작: ID {target.id}, URL: {target.url}")
            
            # 태스크 생성 및 예외 처리
            try:
                # 태스크 생성 및 등록
                task = asyncio.create_task(self.monitor_url(target.id, target.url, target.label))
                
                # 예외 처리 콜백 추가
                def task_done_callback(fut):
                    try:
                        # 태스크가 예외로 종료되었는지 확인
                        if fut.exception():
                            logger.error(f"모니터링 태스크 예외 발생 (ID {target.id}): {fut.exception()}")
                        else:
                            logger.info(f"모니터링 태스크 정상 종료 (ID {target.id})")
                        
                        # 태스크 종료 시 대기열 처리 (다음 항목 시작 가능)
                        asyncio.create_task(self._check_queue_after_task_completion())
                    except asyncio.CancelledError:
                        logger.info(f"모니터링 태스크 취소됨 (ID {target.id})")
                        # 취소된 경우에도 대기열 처리
                        asyncio.create_task(self._check_queue_after_task_completion())
                    except Exception as e:
                        logger.error(f"태스크 콜백 처리 중 오류: {str(e)}")
                
                # 콜백 등록
                task.add_done_callback(task_done_callback)
                
                # 태스크 저장
                self.monitoring_tasks[target.id] = task
                logger.info(f"모니터링 태스크 생성 및 시작 완료: ID {target.id}")
                
                # 태스크가 즉시 시작되었는지 확인
                await asyncio.sleep(0)  # 이벤트 루프에 제어권 양보
                
                if target.id in self.monitoring_tasks and not self.monitoring_tasks[target.id].done():
                    logger.info(f"태스크가 성공적으로 시작됨: ID {target.id}")
                else:
                    logger.warning(f"태스크가 즉시 종료되었거나 실패함: ID {target.id}")
            
            except Exception as e:
                logger.error(f"태스크 생성 중 오류 발생: {str(e)}")
                # 실패 시 상태 롤백
                await self.monitor_service.update_target(target.id, {"is_active": False})
                raise

            return target.id
        except Exception as e:
            logger.error(f"모니터링 시작 중 오류 발생: {str(e)}", exc_info=True)
            raise
            
    async def _process_monitoring_queue(self):
        """대기열에 있는 모니터링 작업을 처리합니다."""
        logger.info("모니터링 대기열 처리 태스크 시작")
        try:
            while True:  # 무한 루프로 계속 처리
                # 활성 태스크 및 탭 수 확인
                active_tasks = sum(1 for task in self.monitoring_tasks.values() if not task.done())
                total_tabs = sum(len(tabs) for tabs in self.tab_pools.values())
                
                # 여유 공간이 있으면 대기열에서 항목 꺼내서 처리
                if active_tasks < self.TOTAL_MAX_TABS and total_tabs < self.TOTAL_MAX_TABS:
                    # 대기열에 항목이 있는지 확인
                    if not self.monitoring_queue.empty():
                        try:
                            # 대기열에서 항목 꺼내기 (비차단 방식)
                            queue_item = self.monitoring_queue.get_nowait()
                            target_id = queue_item["target_id"]
                            target = queue_item["target"]
                            added_time = queue_item["added_time"]
                            wait_time = time.time() - added_time
                            
                            # 대기열 항목 제거
                            if target_id in self.monitoring_queue_tasks:
                                del self.monitoring_queue_tasks[target_id]
                            
                            # 모니터링 시작 로그
                            logger.info(f"대기열에서 모니터링 시작: ID {target_id}, 대기 시간: {wait_time:.1f}초")
                            
                            # 모니터링 상태 업데이트
                            update_data = {
                                "is_active": True,
                                "run_status": "running",
                                "error_count": 0,
                                "last_error": None
                            }
                            await self.monitor_service.update_target(target_id, update_data)
                            
                            # 모니터링 태스크 시작
                            task = asyncio.create_task(self.monitor_url(target_id, target.url, target.label))
                            
                            # 콜백 등록 (다른 대기 항목을 위해)
                            def task_done_callback(fut):
                                try:
                                    if fut.exception():
                                        logger.error(f"대기열에서 시작된 태스크 예외 발생 (ID {target_id}): {fut.exception()}")
                                    else:
                                        logger.info(f"대기열에서 시작된 태스크 정상 종료 (ID {target_id})")
                                    # 태스크 종료 시 다음 대기 항목 처리 시도
                                    asyncio.create_task(self._check_queue_after_task_completion())
                                except Exception as e:
                                    logger.error(f"대기열 태스크 콜백 처리 중 오류: {str(e)}")
                            
                            task.add_done_callback(task_done_callback)
                            
                            # 태스크 저장
                            self.monitoring_tasks[target_id] = task
                            
                            # 대기열 항목 처리 완료 표시
                            self.monitoring_queue.task_done()
                            
                            # 대기열에서 시작됨 알림
                            try:
                                message = (
                                    f"✅ <b>모니터링 대기열 알림</b>\n\n"
                                    f"대상: {target.label}\n"
                                    f"상태: 대기열에서 시작됨\n"
                                    f"대기 시간: {wait_time:.1f}초\n"
                                    f"현재 실행 중인 모니터링: {active_tasks+1}/{self.TOTAL_MAX_TABS}개"
                                )
                                from app.services.notification_service import NotificationService
                                notification_service = NotificationService()
                                await notification_service.send_telegram(message, force_send=True)
                            except Exception as e:
                                logger.error(f"대기열 시작 알림 전송 실패: {str(e)}")
                                
                        except asyncio.QueueEmpty:
                            # 빈 대기열이면 대기
                            pass
                
                # 짧은 대기 후 다시 확인 (CPU 부하 방지)
                await asyncio.sleep(5)
                
        except asyncio.CancelledError:
            logger.info("모니터링 대기열 처리 태스크 취소됨")
        except Exception as e:
            logger.error(f"모니터링 대기열 처리 중 오류 발생: {str(e)}", exc_info=True)
            # 오류 발생 시 태스크 재시작
            await asyncio.sleep(5)  # 잠시 대기 후 재시작
            asyncio.create_task(self._process_monitoring_queue())
            
    async def _check_queue_after_task_completion(self):
        """태스크 완료 후 대기열에서 다음 항목을 처리할 수 있는지 확인합니다."""
        try:
            # 활성 태스크 및 탭 수 확인
            active_tasks = sum(1 for task in self.monitoring_tasks.values() if not task.done())
            total_tabs = sum(len(tabs) for tabs in self.tab_pools.values())
            
            # 대기열에 항목이 있는지 확인
            if hasattr(self, 'monitoring_queue') and not self.monitoring_queue.empty():
                # 여유 공간이 있는지 확인
                if active_tasks < self.TOTAL_MAX_TABS and total_tabs < self.TOTAL_MAX_TABS:
                    logger.info(f"태스크 완료 후 대기열 확인: 여유 공간 있음 (활성 태스크: {active_tasks}/{self.TOTAL_MAX_TABS}, 탭: {total_tabs}/{self.TOTAL_MAX_TABS})")
                    # 대기열 처리를 위해 이벤트 루프에 제어권 양보
                    await asyncio.sleep(0.1)
                else:
                    logger.info(f"태스크 완료 후 대기열 확인: 여유 공간 없음 (활성 태스크: {active_tasks}/{self.TOTAL_MAX_TABS}, 탭: {total_tabs}/{self.TOTAL_MAX_TABS})")
        except Exception as e:
            logger.error(f"대기열 확인 중 오류 발생: {str(e)}")

    async def stop_monitoring(self, target_id: int) -> bool:
        """모니터링을 중지합니다."""
        # 대기열에 있는 항목인지 확인
        if hasattr(self, 'monitoring_queue_tasks') and target_id in self.monitoring_queue_tasks:
            logger.info(f"대기열에 있는 모니터링 중지: ID {target_id}")
            # 대기열 태스크 사전에서 제거
            del self.monitoring_queue_tasks[target_id]
            # 상태 업데이트
            await self.monitor_service.update_target(target_id, {
                "run_status": "stopped",
                "last_error": "사용자가 대기 중인 모니터링을 취소함"
            })
            return True
            
        # 실행 중인 태스크인지 확인
        if target_id not in self.monitoring_tasks:
            return False

        # 모니터링 상태 업데이트 - is_active는 유지하되 run_status만 변경
        await self.monitor_service.update_target(target_id, {
            "run_status": "stopped"
        })

        # 태스크 취소
        task = self.monitoring_tasks[target_id]
        task.cancel()
        
        try:
            await task
        except asyncio.CancelledError:
            pass

        # 리소스 정리
        await self.cleanup_target_resources(target_id)
        
        # 브라우저 컨텍스트 닫기 (이미 cleanup_target_resources에서 처리했을 수 있음)
        if target_id in self.browser_contexts:
            try:
                await self.browser_contexts[target_id].close()
            except:
                pass
            del self.browser_contexts[target_id]

        # 탭 풀 정리 (이미 cleanup_target_resources에서 처리했을 수 있음)
        if target_id in self.tab_pools:
            del self.tab_pools[target_id]
        
        if target_id in self.tab_last_used:
            del self.tab_last_used[target_id]
            
        # 메모리 통계 정리
        if target_id in self.memory_stats:
            del self.memory_stats[target_id]
            
        if target_id in self.last_memory_check:
            del self.last_memory_check[target_id]

        del self.monitoring_tasks[target_id]
        
        # 태스크 종료 후 대기열 확인
        await self._check_queue_after_task_completion()
        
        return True